# Optional. Compose pulls pre-built images from Docker Hub (no local build).
# Image tags are fixed in docker-compose.yml (kyawzayarsoe/ielts-ai-*:latest).

# --- LiveKit Cloud (Speaking/Listening/Reading/Writing live voice) ---
# From LiveKit Cloud → Settings → Keys (do not commit real values)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- Voice agent LLM/STT (pick at least one) ---
# Free-tier friendly OpenAI-compatible LLM (recommended for LiveKit agent)
GROQ_API_KEY=
# Paid OpenAI (optional; enables OpenAI STT/TTS/LLM)
OPENAI_API_KEY=
# OpenAI-compatible base (default Groq). Override if you use another provider.
OPENAI_BASE_URL=https://api.groq.com/openai/v1
