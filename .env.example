# Copy this file to .env and fill in your LiveKit Cloud credentials.
# Values are shared by both the agent and web services in docker-compose.

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Must match agent_name in agent/src/agent.py
AGENT_NAME=ielts-voice-agent

# Host port for the web UI (default: 3000)
WEB_PORT=3000
