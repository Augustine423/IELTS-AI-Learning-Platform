# Copy to .env and fill real values. Never commit .env.
# Compose pulls Hub images (no local build required).

# LiveKit Cloud (room transport / WebRTC) — from your LiveKit project
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# AI brain for chat + voice STT/LLM (LiveKit keys alone are not enough)
# Free tier: https://console.groq.com/keys
GROQ_API_KEY=
# Optional paid alternative / OpenAI TTS
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
