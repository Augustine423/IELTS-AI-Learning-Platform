# LLM — leave empty to use backend/config.yaml.
# With Docker Compose, backend uses http://ollama:11434 via compose env.
OLLAMA_BASE_URL=http://localhost:11434

# Optional online LLM fallback (Groq, OpenRouter, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Optional paid STT (default is free offline whisper)
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional paid TTS (default is free Edge TTS)
ELEVENLABS_API_KEY=
